<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="NeuroPOS.MVVM.View.TransactionPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:Model="clr-namespace:NeuroPOS.MVVM.Model"
    xmlns:VM="clr-namespace:NeuroPOS.MVVM.ViewModel"
    xmlns:syncfusion="clr-namespace:Syncfusion.Maui.DataGrid;assembly=Syncfusion.Maui.DataGrid"
    x:DataType="VM:TransactionVM"
    BackgroundColor="{StaticResource NPLightBg}">

    <VerticalStackLayout Padding="32,32,32,24" Spacing="24">
        <!--  Title Section  -->
        <Label
            Margin="0,0,0,2"
            FontSize="28"
            StyleClass="TitleText"
            Text="Transactions" />
        <Label
            Margin="0,0,0,18"
            FontSize="16"
            StyleClass="SubtitleText"
            Text="View and manage all transactions" />

        <!--  Floating Filter Bar  -->
        <Frame
            Margin="0,0,0,10"
            Padding="0"
            BackgroundColor="White"
            CornerRadius="16"
            HasShadow="True">
            <HorizontalStackLayout Padding="18,10" Spacing="12">
                <Entry
                    BackgroundColor="{StaticResource NPLightBg}"
                    HeightRequest="36"
                    HorizontalOptions="Fill"
                    Placeholder="Search transactions..." />
                <Button
                    Padding="16,0"
                    BackgroundColor="{StaticResource NPPrimaryBlue}"
                    CornerRadius="8"
                    FontAttributes="Bold"
                    HeightRequest="36"
                    Text="Date Range"
                    TextColor="White" />
                <Button
                    Padding="16,0"
                    BackgroundColor="{StaticResource NPPrimaryBlue}"
                    CornerRadius="8"
                    FontAttributes="Bold"
                    HeightRequest="36"
                    Text="Status"
                    TextColor="White" />
            </HorizontalStackLayout>
        </Frame>

        <!--  Card with shadow for DataGrid  -->
        <Frame
            Margin="0,10,0,10"
            Padding="0"
            BackgroundColor="{StaticResource NPCardBg}"
            CornerRadius="16"
            HeightRequest="500">
            <Frame.Shadow>
                <Shadow
                    Brush="Black"
                    Opacity="0.12"
                    Radius="16"
                    Offset="0,8" />

            </Frame.Shadow>
            <syncfusion:SfDataGrid
                x:Name="dataGrid"
                AutoGenerateColumnsMode="None"
                BackgroundColor="Transparent"
                ItemsSource="{Binding Transactions}">
                <syncfusion:SfDataGrid.Columns>
                    <syncfusion:DataGridTextColumn
                        CellTextAlignment="Start"
                        ColumnWidthMode="Auto"
                        HeaderText="TRANSACTION ID"
                        HeaderTextAlignment="Start"
                        MappingName="Id" />
                    <syncfusion:DataGridTextColumn
                        CellTextAlignment="Start"
                        HeaderText="Type"
                        MappingName="TransactionType" />
                    <syncfusion:DataGridTextColumn
                        CellTextAlignment="Start"
                        HeaderText="Date"
                        MappingName="FormattedDate" />
                    <syncfusion:DataGridNumericColumn
                        CellTextAlignment="Start"
                        HeaderText="Items"
                        MappingName="ItemCount" />
                    <syncfusion:DataGridTextColumn
                        CellTextAlignment="Start"
                        HeaderText="Amount"
                        MappingName="TotalAmount" />
                </syncfusion:SfDataGrid.Columns>
            </syncfusion:SfDataGrid>
        </Frame>
    </VerticalStackLayout>
</ContentPage>