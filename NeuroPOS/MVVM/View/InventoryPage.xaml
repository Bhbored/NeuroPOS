<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="NeuroPOS.MVVM.View.InventoryPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:NeuroPOS.MVVM.Model"
    xmlns:syncfusion="clr-namespace:Syncfusion.Maui.DataGrid;assembly=Syncfusion.Maui.DataGrid"
    BackgroundColor="{StaticResource NPLightBg}">

    <VerticalStackLayout Padding="0" Spacing="0">
        <!--  Page Title and Description  -->
        <Label
            Margin="32,32,0,0"
            StyleClass="TitleText"
            Text="Inventory" />
        <Label
            Margin="32,0,0,16"
            StyleClass="SubtitleText"
            Text="Manage your products and categories." />

        <!--  Search and Action Bar  -->
        <HorizontalStackLayout Margin="32,0,32,0" Spacing="12">
            <Border
                HeightRequest="44"
                HorizontalOptions="Fill"
                StyleClass="CardStyle">
                <HorizontalStackLayout Padding="12,0" Spacing="8">
                    <Image
                        HeightRequest="20"
                        Source="search.png"
                        VerticalOptions="Center"
                        WidthRequest="20" />
                    <Entry
                        BackgroundColor="Transparent"
                        FontSize="15"
                        Placeholder="Search products by name, ID, or category"
                        TextColor="{StaticResource NPTextMain}"
                        VerticalOptions="Center" />
                </HorizontalStackLayout>
            </Border>
            <Button
                HeightRequest="44"
                StyleClass="CardStyle"
                Text="Filter"
                TextColor="{StaticResource NPTextMain}"
                WidthRequest="60" />
            <Button
                HeightRequest="44"
                StyleClass="CardStyle"
                Text="Sort"
                TextColor="{StaticResource NPTextMain}"
                WidthRequest="60" />
        </HorizontalStackLayout>

        <!--  Add Product/Category Buttons  -->
        <HorizontalStackLayout
            Margin="32,18,32,0"
            HorizontalOptions="End"
            Spacing="12">
            <Button
                BackgroundColor="{StaticResource NPPrimaryBlue}"
                FontAttributes="Bold"
                HeightRequest="44"
                StyleClass="CardStyle"
                Text="+ Add Product"
                TextColor="White"
                WidthRequest="140" />
            <Button
                HeightRequest="44"
                StyleClass="CardStyle"
                Text="Add Category"
                TextColor="{StaticResource NPTextMain}"
                WidthRequest="130" />
        </HorizontalStackLayout>

        <!--  DataGrid  -->
        <Border Margin="32,24,32,0" StyleClass="CardStyle">
            <syncfusion:SfDataGrid
                x:Name="InventoryDataGrid"
                AutoGenerateColumnsMode="None"
                GridLinesVisibility="None"
                HeaderGridLinesVisibility="None"
                HeaderRowHeight="44"
                ItemsSource="{Binding Products}"
                RowHeight="56"
                SelectionMode="None">

                <syncfusion:SfDataGrid.Columns>
                    <!--  Checkbox Column  -->
                    <syncfusion:DataGridTemplateColumn Width="40">
                        <syncfusion:DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <CheckBox IsChecked="False" />
                            </DataTemplate>
                        </syncfusion:DataGridTemplateColumn.CellTemplate>
                    </syncfusion:DataGridTemplateColumn>

                    <!--  Product Column  -->
                    <syncfusion:DataGridTemplateColumn Width="220" HeaderText="PRODUCT">
                        <syncfusion:DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <HorizontalStackLayout Spacing="12">
                                    <Image
                                        HeightRequest="36"
                                        Source="{Binding ImageUrl}"
                                        WidthRequest="36" />
                                    <VerticalStackLayout Spacing="0">
                                        <Label
                                            FontAttributes="Bold"
                                            FontSize="15"
                                            Text="{Binding Name}"
                                            TextColor="{StaticResource NPTextMain}" />
                                        <Label
                                            FontSize="13"
                                            Text="{Binding FormattedDate}"
                                            TextColor="{StaticResource NPTextSecondary}" />
                                    </VerticalStackLayout>
                                </HorizontalStackLayout>
                            </DataTemplate>
                        </syncfusion:DataGridTemplateColumn.CellTemplate>
                    </syncfusion:DataGridTemplateColumn>

                    <!--  Category Column  -->
                    <syncfusion:DataGridTemplateColumn Width="110" HeaderText="CATEGORY">
                        <syncfusion:DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Label
                                    FontSize="13"
                                    Text="{Binding CategoryName}"
                                    TextColor="{StaticResource NPTextMain}" />
                            </DataTemplate>
                        </syncfusion:DataGridTemplateColumn.CellTemplate>
                    </syncfusion:DataGridTemplateColumn>

                    <!--  Stock Level Column  -->
                    <syncfusion:DataGridTemplateColumn Width="140" HeaderText="STOCK LEVEL">
                        <syncfusion:DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <HorizontalStackLayout Spacing="8" VerticalOptions="Center">
                                    <BoxView
                                        BackgroundColor="{StaticResource NPStockGreen}"
                                        HeightRequest="8"
                                        WidthRequest="60" />
                                    <Label
                                        FontSize="14"
                                        Text="{Binding Stock}"
                                        TextColor="{StaticResource NPTextMain}" />
                                </HorizontalStackLayout>
                            </DataTemplate>
                        </syncfusion:DataGridTemplateColumn.CellTemplate>
                    </syncfusion:DataGridTemplateColumn>

                    <!--  Price Column  -->
                    <syncfusion:DataGridTextColumn
                        Width="100"
                        HeaderText="PRICE"
                        MappingName="Price" />

                    <!--  Actions Column  -->
                    <syncfusion:DataGridTemplateColumn Width="80">
                        <syncfusion:DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <HorizontalStackLayout HorizontalOptions="End" Spacing="12">
                                    <ImageButton
                                        HeightRequest="20"
                                        Source="edit.png"
                                        WidthRequest="20" />
                                    <ImageButton
                                        HeightRequest="20"
                                        Source="delete.png"
                                        WidthRequest="20" />
                                </HorizontalStackLayout>
                            </DataTemplate>
                        </syncfusion:DataGridTemplateColumn.CellTemplate>
                    </syncfusion:DataGridTemplateColumn>
                </syncfusion:SfDataGrid.Columns>
            </syncfusion:SfDataGrid>
        </Border>
    </VerticalStackLayout>
</ContentPage>