<?xml version="1.0" encoding="utf-8" ?>
<?xaml-comp compile="true" ?>
<ResourceDictionary xmlns="http://schemas.microsoft.com/dotnet/2021/maui" xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">
    <Style
        ApplyToDerivedTypes="True"
        Class="MarginT15"
        TargetType="View">
        <Setter Property="Margin" Value="0,15,0,0" />
    </Style>
    <Style
        ApplyToDerivedTypes="True"
        Class="Padding25"
        TargetType="Layout">
        <Setter Property="Padding" Value="25" />
    </Style>
    <Style
        ApplyToDerivedTypes="True"
        Class="CardStyle"
        TargetType="Border">
        <Setter Property="StrokeShape" Value="RoundRectangle 16" />
        <Setter Property="Stroke" Value="{StaticResource Gray200}" />
        <Setter Property="BackgroundColor" Value="{StaticResource White}" />
        <Setter Property="Margin" Value="0,10,0,10" />
        <Setter Property="Padding" Value="0" />
    </Style>
    <Style
        ApplyToDerivedTypes="True"
        Class="TitleText"
        TargetType="Label">
        <Setter Property="FontFamily" Value="PoppinsBold" />
        <Setter Property="FontSize" Value="20" />
        <Setter Property="TextColor" Value="{StaticResource Black}" />
    </Style>
    <Style
        ApplyToDerivedTypes="True"
        Class="SubtitleText"
        TargetType="Label">
        <Setter Property="FontFamily" Value="PoppinsRegular" />
        <Setter Property="FontSize" Value="16" />
        <Setter Property="TextColor" Value="{StaticResource Gray600}" />
    </Style>
    <Style
        ApplyToDerivedTypes="True"
        Class="NormalText"
        TargetType="Label">
        <Setter Property="FontFamily" Value="PoppinsRegular" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="TextColor" Value="{StaticResource Gray900}" />
    </Style>
    <Style
        ApplyToDerivedTypes="True"
        Class="OrderSummaryBg"
        TargetType="Grid">
        <Setter Property="BackgroundColor" Value="{StaticResource Gray100}" />
        <Setter Property="Padding" Value="20,16" />
    </Style>

    <!--  not working  -->
    <Style
        ApplyToDerivedTypes="True"
        Class="ProductImageStyle"
        TargetType="Image">

        <Setter Property="HeightRequest" Value="140" />
        <Setter Property="WidthRequest" Value="140" />
        <Setter Property="Aspect" Value="AspectFill" />

        <Setter Property="HorizontalOptions" Value="Fill" />
        <Setter Property="VerticalOptions" Value="Start" />
        <Setter Property="Clip">
            <Setter.Value>
                <RoundRectangleGeometry CornerRadius="16" />
            </Setter.Value>
        </Setter>
    </Style>



    <!--  Color Palette for NeuroPOS Theme  -->
    <Color x:Key="NPPrimaryBlue">#2D7FF9</Color>
    <Color x:Key="NPAccentYellow">#F9A825</Color>
    <Color x:Key="NPLightBg">#F6F8FB</Color>
    <Color x:Key="NPCardBg">#FFFFFF</Color>
    <Color x:Key="NPDivider">#E5E7EB</Color>
    <Color x:Key="NPTextMain">#212121</Color>
    <Color x:Key="NPTextSecondary">#6E6E6E</Color>
    <Color x:Key="NPTextMuted">#B0B0B0</Color>
    <Color x:Key="NPStockGreen">#1DB954</Color>
    <Color x:Key="NPStockRed">#E53935</Color>
    <SolidColorBrush x:Key="NPPrimaryBlueBrush" Color="{StaticResource NPPrimaryBlue}" />
    <SolidColorBrush x:Key="NPAccentYellowBrush" Color="{StaticResource NPAccentYellow}" />
    <SolidColorBrush x:Key="NPLightBgBrush" Color="{StaticResource NPLightBg}" />
    <SolidColorBrush x:Key="NPCardBgBrush" Color="{StaticResource NPCardBg}" />
    <SolidColorBrush x:Key="NPDividerBrush" Color="{StaticResource NPDivider}" />
    <SolidColorBrush x:Key="NPTextMainBrush" Color="{StaticResource NPTextMain}" />
    <SolidColorBrush x:Key="NPTextSecondaryBrush" Color="{StaticResource NPTextSecondary}" />
    <SolidColorBrush x:Key="NPTextMutedBrush" Color="{StaticResource NPTextMuted}" />
    <SolidColorBrush x:Key="NPStockGreenBrush" Color="{StaticResource NPStockGreen}" />
    <SolidColorBrush x:Key="NPStockRedBrush" Color="{StaticResource NPStockRed}" />
</ResourceDictionary>