<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="NeuroPOS.MVVM.View.CashRegisterPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:Converters="clr-namespace:NeuroPOS.Converters"
    xmlns:vm="clr-namespace:NeuroPOS.MVVM.ViewModel"
    BackgroundColor="{StaticResource NPLightBg}">

    <ContentPage.Resources>
        <Converters:StatusToColorConverter x:Key="StatusToColorConverter" />
        <Converters:FilterButtonColorConverter x:Key="FilterButtonColorConverter" />
        <Converters:FilterButtonTextColorConverter x:Key="FilterButtonTextColorConverter" />
    </ContentPage.Resources>

    <ContentPage.BindingContext>
        <vm:CashRegisterVM />
    </ContentPage.BindingContext>

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="25">

            <!--  Header  -->
            <Label
                Margin="0,0,0,10"
                StyleClass="LargeTitle"
                Text="Cash Register" />

            <!--  Summary Cards  -->
            <Grid ColumnDefinitions="*,*,*,*" ColumnSpacing="15">

                <!--  Total Sales Card  -->
                <Border Padding="20" StyleClass="ModernCardShadow">
                    <Grid RowDefinitions="Auto,Auto" RowSpacing="8">
                        <Grid ColumnDefinitions="*,Auto">
                            <Label
                                StyleClass="SubtitleText"
                                Text="Sales"
                                TextColor="{StaticResource NPTextSecondary}" />
                            <Image
                                Grid.Column="1"
                                HeightRequest="20"
                                Source="wallet.png"
                                WidthRequest="20" />
                        </Grid>
                        <Label
                            FontSize="24"
                            StyleClass="LargeTitle"
                            Text="{Binding CashRegister.TotalIncome, StringFormat='${0:N0}'}"
                            TextColor="{StaticResource NPStockGreen}" />
                    </Grid>
                </Border>

                <!--  Total Purchases Card  -->
                <Border
                    Grid.Column="1"
                    Padding="20"
                    StyleClass="ModernCardShadow">
                    <Grid RowDefinitions="Auto,Auto" RowSpacing="8">
                        <Grid ColumnDefinitions="*,Auto">
                            <Label
                                StyleClass="SubtitleText"
                                Text="Purchases"
                                TextColor="{StaticResource NPTextSecondary}" />
                            <Image
                                Grid.Column="1"
                                HeightRequest="20"
                                Source="redcart.png"
                                WidthRequest="20" />
                        </Grid>
                        <Label
                            FontSize="24"
                            StyleClass="LargeTitle"
                            Text="{Binding CashRegister.TotalExpenses, StringFormat='${0:N0}'}"
                            TextColor="{StaticResource NPStockRed}" />
                    </Grid>
                </Border>

                <!--  Net Balance Card  -->
                <Border
                    Grid.Column="2"
                    Padding="20"
                    StyleClass="ModernCardShadow">
                    <Grid RowDefinitions="Auto,Auto" RowSpacing="8">
                        <Grid ColumnDefinitions="*,Auto">
                            <Label
                                StyleClass="SubtitleText"
                                Text="Balance"
                                TextColor="{StaticResource NPTextSecondary}" />
                            <Image
                                Grid.Column="1"
                                HeightRequest="20"
                                Source="credit.png"
                                WidthRequest="20" />
                        </Grid>
                        <Label
                            FontSize="24"
                            StyleClass="LargeTitle"
                            Text="{Binding CashRegister.NetProfit, StringFormat='${0:N0}'}"
                            TextColor="{StaticResource NPPrimaryBlue}" />
                    </Grid>
                </Border>

                <!--  Total Transactions Card  -->
                <Border
                    Grid.Column="3"
                    Padding="20"
                    StyleClass="ModernCardShadow">
                    <Grid RowDefinitions="Auto,Auto" RowSpacing="8">
                        <Grid ColumnDefinitions="*,Auto">
                            <Label
                                StyleClass="SubtitleText"
                                Text="Transactions"
                                TextColor="{StaticResource NPTextSecondary}" />
                            <Image
                                Grid.Column="1"
                                HeightRequest="20"
                                Source="transaction.png"
                                WidthRequest="20" />
                        </Grid>
                        <Label
                            FontSize="24"
                            StyleClass="LargeTitle"
                            Text="{Binding CashRegister.TotalTransactions}"
                            TextColor="{StaticResource NPTextMain}" />
                    </Grid>
                </Border>

            </Grid>

            <!--  Main Content  -->
            <Grid ColumnDefinitions="2*,1*" ColumnSpacing="20">

                <!--  Transactions Section  -->
                <VerticalStackLayout Grid.Column="0" Spacing="15">

                    <!--  Transactions Header  -->
                    <Grid ColumnDefinitions="*,Auto">
                        <Label
                            Grid.Column="0"
                            StyleClass="TitleText"
                            Text="Transactions" />

                        <!--  Filter Buttons  -->
                        <HorizontalStackLayout Grid.Column="1" Spacing="8">
                            <Button
                                Margin="0,0,8,0"
                                Padding="16,8"
                                BackgroundColor="{Binding SelectedFilter, Converter={StaticResource FilterButtonColorConverter}, ConverterParameter=All}"
                                Command="{Binding FilterCommand}"
                                CommandParameter="All"
                                CornerRadius="20"
                                FontFamily="PoppinsBold"
                                FontSize="12"
                                Text="All"
                                TextColor="{Binding SelectedFilter, Converter={StaticResource FilterButtonTextColorConverter}, ConverterParameter=All}" />
                            <Button
                                Margin="0,0,8,0"
                                Padding="16,8"
                                BackgroundColor="{Binding SelectedFilter, Converter={StaticResource FilterButtonColorConverter}, ConverterParameter=Paid}"
                                Command="{Binding FilterCommand}"
                                CommandParameter="Paid"
                                CornerRadius="20"
                                FontFamily="PoppinsBold"
                                FontSize="12"
                                Text="Paid"
                                TextColor="{Binding SelectedFilter, Converter={StaticResource FilterButtonTextColorConverter}, ConverterParameter=Paid}" />
                            <Button
                                Margin="0,0,8,0"
                                Padding="16,8"
                                BackgroundColor="{Binding SelectedFilter, Converter={StaticResource FilterButtonColorConverter}, ConverterParameter=Pending}"
                                Command="{Binding FilterCommand}"
                                CommandParameter="Pending"
                                CornerRadius="20"
                                FontFamily="PoppinsBold"
                                FontSize="12"
                                Text="Pending"
                                TextColor="{Binding SelectedFilter, Converter={StaticResource FilterButtonTextColorConverter}, ConverterParameter=Pending}" />
                        </HorizontalStackLayout>
                    </Grid>

                    <!--  Transactions Table  -->
                    <Border
                        Padding="0"
                        HeightRequest="350"
                        StyleClass="ModernCardShadow">
                        <Grid RowDefinitions="Auto,*">

                            <!--  Table Header  -->
                            <Grid
                                BackgroundColor="{StaticResource NPLightBg}"
                                ColumnDefinitions="Auto,*,Auto,Auto,Auto"
                                StyleClass="TableRow">
                                <Label
                                    Grid.Column="0"
                                    Margin="20,16,0,16"
                                    StyleClass="ColumnHeader"
                                    Text="DATE" />
                                <Label
                                    Grid.Column="1"
                                    Margin="0,16,0,16"
                                    StyleClass="ColumnHeader"
                                    Text="TYPE" />
                                <Label
                                    Grid.Column="2"
                                    Margin="0,16,0,16"
                                    StyleClass="ColumnHeader"
                                    Text="ITEM COUNT" />
                                <Label
                                    Grid.Column="3"
                                    Margin="0,16,0,16"
                                    StyleClass="ColumnHeader"
                                    Text="TOTAL AMOUNT" />
                                <Label
                                    Grid.Column="4"
                                    Margin="0,16,20,16"
                                    StyleClass="ColumnHeader"
                                    Text="STATUS" />
                            </Grid>

                            <!--  Table Content  -->
                            <CollectionView
                                Grid.Row="1"
                                ItemsSource="{Binding Transactions}"
                                SelectionMode="None">
                                <CollectionView.ItemTemplate>
                                    <DataTemplate>
                                        <Grid ColumnDefinitions="Auto,*,Auto,Auto,Auto" StyleClass="TableRow">

                                            <!--  Date  -->
                                            <Label
                                                Grid.Column="0"
                                                Margin="20,16,0,16"
                                                StyleClass="TableCell"
                                                Text="{Binding FormattedDate}" />

                                            <!--  Type  -->
                                            <Label
                                                Grid.Column="1"
                                                Margin="0,16,0,16"
                                                StyleClass="TableCell"
                                                Text="{Binding TransactionType, StringFormat='{0:U}'}" />

                                            <!--  Item Count  -->
                                            <Label
                                                Grid.Column="2"
                                                Margin="0,16,0,16"
                                                StyleClass="TableCell"
                                                Text="{Binding CalculatedItemCount}" />

                                            <!--  Total Amount  -->
                                            <Label
                                                Grid.Column="3"
                                                Margin="0,16,0,16"
                                                StyleClass="TableCell"
                                                Text="{Binding TotalAmount, StringFormat='${0:N2}'}" />

                                            <!--  Status  -->
                                            <Border
                                                Grid.Column="4"
                                                Margin="0,16,20,16"
                                                BackgroundColor="{Binding IsPaid, Converter={StaticResource StatusToColorConverter}}"
                                                StyleClass="StatusBadge">
                                                <Label
                                                    FontFamily="PoppinsBold"
                                                    FontSize="12"
                                                    StyleClass="TableCell"
                                                    Text="{Binding Status}"
                                                    TextColor="White" />
                                            </Border>

                                        </Grid>
                                    </DataTemplate>
                                </CollectionView.ItemTemplate>
                            </CollectionView>

                        </Grid>
                    </Border>

                </VerticalStackLayout>

                <!--  Balance Overview Section  -->
                <VerticalStackLayout Grid.Column="1" Spacing="15">

                    <Label StyleClass="TitleText" Text="Balance Overview" />

                    <Border
                        Padding="20"
                        HeightRequest="250"
                        StyleClass="ModernCardShadow">
                        <VerticalStackLayout Spacing="20">

                            <!--  Paid Status  -->
                            <VerticalStackLayout Spacing="8">
                                <Grid ColumnDefinitions="*,Auto">
                                    <Label
                                        StyleClass="NormalText"
                                        Text="Paid"
                                        TextColor="{StaticResource NPTextMain}" />
                                    <Label
                                        Grid.Column="1"
                                        StyleClass="NormalText"
                                        Text="{Binding CashRegister.TotalIncome, StringFormat='${0:N0}'}"
                                        TextColor="{StaticResource NPStockGreen}" />
                                </Grid>
                                <ProgressBar
                                    BackgroundColor="{StaticResource NPLightBg}"
                                    HeightRequest="8"
                                    Progress="0.85"
                                    ProgressColor="{StaticResource NPStockGreen}" />
                            </VerticalStackLayout>

                            <!--  Pending Status  -->
                            <VerticalStackLayout Spacing="8">
                                <Grid ColumnDefinitions="*,Auto">
                                    <Label
                                        StyleClass="NormalText"
                                        Text="Pending"
                                        TextColor="{StaticResource NPTextMain}" />
                                    <Label
                                        Grid.Column="1"
                                        StyleClass="NormalText"
                                        Text="{Binding CashRegister.TotalCreditSales, StringFormat='${0:N0}'}"
                                        TextColor="{StaticResource NPAccentYellow}" />
                                </Grid>
                                <ProgressBar
                                    BackgroundColor="{StaticResource NPLightBg}"
                                    HeightRequest="8"
                                    Progress="0.15"
                                    ProgressColor="{StaticResource NPAccentYellow}" />
                            </VerticalStackLayout>

                            <!--  Overdue Status  -->
                            <VerticalStackLayout Spacing="8">
                                <Grid ColumnDefinitions="*,Auto">
                                    <Label
                                        StyleClass="NormalText"
                                        Text="Overdue"
                                        TextColor="{StaticResource NPTextMain}" />
                                    <Label
                                        Grid.Column="1"
                                        StyleClass="NormalText"
                                        Text="$300"
                                        TextColor="{StaticResource NPStockRed}" />
                                </Grid>
                                <ProgressBar
                                    BackgroundColor="{StaticResource NPLightBg}"
                                    HeightRequest="8"
                                    Progress="0.05"
                                    ProgressColor="{StaticResource NPStockRed}" />
                            </VerticalStackLayout>

                        </VerticalStackLayout>
                    </Border>

                </VerticalStackLayout>

            </Grid>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>