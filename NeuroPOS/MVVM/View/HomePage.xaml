<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="NeuroPOS.MVVM.View.HomePage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:Converters="clr-namespace:NeuroPOS.Converters"
    xmlns:Model="clr-namespace:NeuroPOS.MVVM.Model"
    xmlns:VM="clr-namespace:NeuroPOS.MVVM.ViewModel"
    xmlns:data="clr-namespace:Syncfusion.Maui.DataSource;assembly=Syncfusion.Maui.DataSource"
    xmlns:editors="clr-namespace:Syncfusion.Maui.Inputs;assembly=Syncfusion.Maui.Inputs"
    xmlns:syncfusion="clr-namespace:Syncfusion.Maui.ListView;assembly=Syncfusion.Maui.ListView"
    x:Name="HomePageView"
    x:DataType="VM:HomeVM"
    BackgroundColor="{StaticResource NPLightBg}">
    <ContentPage.Resources>
        <Converters:DTSelector x:Key="TemplateSelector"/>
        <Converters:IntToBoolConverter x:Key="IntToBoolConverter"/>
        <Converters:IntToInverseBoolConverter x:Key="IntToInverseBoolConverter"/>
        <Converters:CategoryTemplateSelector x:Key="CategoryTemplateSelector"/>
    </ContentPage.Resources>

    <Grid ColumnDefinitions=".75*,.25*">
        <!--  Left Column: Top Bar, Filter Bar, Product List  -->
        <Grid Grid.Column="0"
                RowDefinitions="Auto,*">
            <!--  Top Bar: Title and Search (white background)  -->
            <Grid
                Grid.Row="0"
                Padding="24,24,24,16"
                BackgroundColor="White"
                ColumnDefinitions="Auto,*"
                VerticalOptions="Start">
                <Label
                    FontFamily="PoppinsBold"
                    FontSize="24"
                    Text="NeuroPOS"
                    TextColor="{StaticResource NPPrimaryBlue}"
                    VerticalOptions="Center"/>
                <VerticalStackLayout Grid.Column="1">
                    <Border
                        Margin="24,0,0,0"
                        BackgroundColor="{StaticResource NPCardBg}"
                        HorizontalOptions="Fill"
                        StrokeShape="RoundRectangle 5"
                        VerticalOptions="Start">
                        <editors:SfAutocomplete
                            x:Name="autocomplete"
                            DisplayMemberPath="Name"
                            EnableAutoSize="True"
                            HighlightedTextColor="{StaticResource NPPrimaryBlue}"
                            HighlightedTextFontAttributes="Bold"
                            ItemsSource="{Binding Products}"
                            MaxDropDownHeight="250"
                            Placeholder="Search Product ..."
                            SelectedValue="{Binding SelectedProducts, Mode=TwoWay}"
                            SelectedValuePath="Name"
                            SelectionChanged="autocomplete_SelectionChanged"
                            SelectionMode="Multiple"
                            Stroke="Transparent"
                            StyleClass="TitleText"
                            TextHighlightMode="FirstOccurrence"
                            TextMemberPath="Name"
                            TokensWrapMode="Wrap"
                            VerticalOptions="Start"/>
                    </Border>
                    <HorizontalStackLayout Margin="24,10,0,-20"
                            Spacing="15">
                        <HorizontalStackLayout Spacing="8">
                            <Label StyleClass="TitleText"
                                    Text="Search Filter :"/>
                            <Label
                                x:Name="searchFilterValue"
                                StyleClass="TitleText"
                                Text="0"/>
                        </HorizontalStackLayout>
                        <HorizontalStackLayout Spacing="8">
                            <Label StyleClass="TitleText"
                                    Text="Selected Items :"/>
                            <Label
                                x:Name="selectedValue"
                                StyleClass="TitleText"
                                Text="0"/>
                        </HorizontalStackLayout>
                    </HorizontalStackLayout>
                </VerticalStackLayout>

            </Grid>
            <!--  Divider below top bar  -->
            <BoxView
                Grid.Row="1"
                BackgroundColor="{StaticResource NPDivider}"
                HeightRequest="1"
                HorizontalOptions="Fill"
                VerticalOptions="End"/>
            <!--  Everything below top bar: filter bar + product list, all with NPDivider background  -->
            <Grid
                Grid.Row="2"
                Padding="0,0,0,0"
                BackgroundColor="{StaticResource NPLightBg}"
                ColumnDefinitions=".7*,.3*"
                RowDefinitions="Auto,*">
                <!--  Category Filter Bar (Dynamic CollectionView + All Button)  -->
                <Grid
                    Grid.Row="0"
                    Grid.Column="0"
                    Margin="24,10,0,0"
                    ColumnDefinitions="Auto,*"
                    VerticalOptions="Center">

                    <!--  All Button  -->
                    <Border
                        Grid.Column="0"
                        Margin="4"
                        Padding="12,8"
                        BackgroundColor="{StaticResource NPAccentYellow}"
                        Stroke="{StaticResource NPAccentYellow}"
                        StrokeShape="RoundRectangle 8"
                        StrokeThickness="2">
                        <HorizontalStackLayout Spacing="8">
                            <Label
                                FontFamily="PoppinsBold"
                                FontSize="14"
                                Text="All"
                                TextColor="White"
                                VerticalOptions="Center"/>
                        </HorizontalStackLayout>
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding SwitchCategoryState}"
                                    CommandParameter="All"/>
                        </Border.GestureRecognizers>
                    </Border>

                    <!--  Categories CollectionView with proper sizing  -->
                    <CollectionView
                        x:Name="CategoriesCollectionView"
                        Grid.Column="1"
                        Margin="8,0,0,0"
                        HorizontalOptions="Fill"
                        HorizontalScrollBarVisibility="Always"
                        ItemTemplate="{StaticResource CategoryTemplateSelector}"
                        ItemsSource="{Binding Categories}"
                        VerticalOptions="Center">
                        <CollectionView.ItemsLayout>
                            <LinearItemsLayout ItemSpacing="8"
                                    Orientation="Horizontal"/>
                        </CollectionView.ItemsLayout>
                    </CollectionView>
                </Grid>
                <!--  sort and clear buttons  -->
                <HorizontalStackLayout
                    Grid.Row="0"
                    Grid.Column="1"
                    Margin="0,10,24,0"
                    HorizontalOptions="Center"
                    Spacing="12"
                    VerticalOptions="Center">

                    <!--  Sort Button  -->
                    <Border
                        Padding="16,8"
                        BackgroundColor="{StaticResource NPPrimaryBlue}"
                        Stroke="{StaticResource NPDivider}"
                        StrokeShape="RoundRectangle 20"
                        StrokeThickness="1">
                        <HorizontalStackLayout Spacing="8">
                            <Image
                                x:Name="Icon"
                                Aspect="AspectFill"
                                VerticalOptions="Center"
                                WidthRequest="16"/>
                            <Label
                                FontSize="14"
                                StyleClass="NormalText"
                                Text="{Binding SortLabel}"
                                TextColor="{StaticResource NPLightBg}"/>
                        </HorizontalStackLayout>
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding ToggleSortCommand}"
                                    Tapped="TapGestureRecognizer_Tapped"/>
                        </Border.GestureRecognizers>
                    </Border>

                    <!--  Clear Selection Button (only visible when items are selected)  -->
                    <Border
                        Padding="16,8"
                        BackgroundColor="#FF6B6B"
                        IsVisible="{Binding HasSelectedItems}"
                        Stroke="{StaticResource NPDivider}"
                        StrokeShape="RoundRectangle 20"
                        StrokeThickness="1">
                        <HorizontalStackLayout Spacing="8">
                            <Label
                                FontFamily="PoppinsBold"
                                FontSize="14"
                                Text="×"
                                TextColor="White"
                                VerticalOptions="Center"/>
                            <Label
                                FontSize="14"
                                StyleClass="NormalText"
                                Text="Clear All"
                                TextColor="White"/>
                        </HorizontalStackLayout>
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding ClearAllSelectionsCommand}"/>
                        </Border.GestureRecognizers>
                    </Border>

                </HorizontalStackLayout>

                <!--  Product CollectionView  -->
                <syncfusion:SfListView
                    x:Name="listView"
                    Grid.Row="1"
                    Grid.ColumnSpan="2"
                    Margin="24,10,24,0"
                    AutoFitMode="Height"
                    EnableFadeOnScroll="True"
                    ItemSize="250"
                    ItemSpacing="5"
                    ItemTemplate="{StaticResource TemplateSelector}"
                    ItemsSource="{Binding DataSource.DisplayItems}"
                    Orientation="Vertical"
                    SelectedItems="{Binding SelectedItems}"
                    SelectionBackground="Red"
                    SelectionGesture="Tap"
                    SelectionMode="Multiple">
                    <syncfusion:SfListView.ItemsLayout>
                        <syncfusion:GridLayout SpanCount="4"/>
                    </syncfusion:SfListView.ItemsLayout>
                    <syncfusion:SfListView.EmptyView>
                        <VerticalStackLayout
                            Padding="30"
                            HorizontalOptions="Center"
                            Spacing="12"
                            VerticalOptions="Center">

                            <!--  Placeholder animation image  -->
                            <Image
                                Aspect="AspectFit"
                                Background="Transparent"
                                BackgroundColor="Transparent"
                                HeightRequest="160"
                                IsAnimationPlaying="True"
                                Source="noproduct.gif"/>

                            <!--  Message  -->
                            <Label
                                FontSize="16"
                                HorizontalTextAlignment="Center"
                                StyleClass="TitleText"
                                Text="No products have been added yet."
                                TextColor="{StaticResource NPTextSecondary}"/>
                        </VerticalStackLayout>
                    </syncfusion:SfListView.EmptyView>
                </syncfusion:SfListView>


            </Grid>
        </Grid>
        <!--  Right Column: Order Summary  -->
        <Border
            Grid.Column="1"
            BackgroundColor="{StaticResource NPDivider}"
            StrokeShape="RoundRectangle 24"
            StrokeThickness="0">
            <Grid Padding="0,0,0,0"
                    RowDefinitions="Auto,4,*,4,Auto">
                <!--  Header  -->
                <StackLayout
                    Grid.Row="0"
                    Padding="24,24,24,8"
                    BackgroundColor="{StaticResource NPDivider}"
                    Spacing="2">
                    <Label
                        StyleClass="TitleText"
                        Text="Current Order"
                        TextColor="{StaticResource NPTextMain}"/>
                    <Label
                        StyleClass="SubtitleText"
                        Text="{Binding OrderDateTime}"
                        TextColor="{StaticResource NPTextSecondary}"/>
                </StackLayout>
                <!--  Divider above order items (card width)  -->
                <BoxView
                    Grid.Row="1"
                    BackgroundColor="{StaticResource NPDivider}"
                    HeightRequest="1"
                    HorizontalOptions="Center"
                    WidthRequest="320"/>
                <!--  Order Items Card  -->
                <Border
                    Grid.Row="2"
                    Margin="24,0,24,0"
                    Padding="12"
                    BackgroundColor="White"
                    StrokeShape="RoundRectangle 18"
                    StrokeThickness="0"
                    VerticalOptions="Fill">
                    <Border.Shadow>
                        <Shadow
                            Brush="Black"
                            Opacity="0.3"
                            Radius="12"
                            Offset="5,5"/>
                    </Border.Shadow>
                    <Grid VerticalOptions="Fill">
                        <!--  Cart Items  -->
                        <ScrollView IsVisible="{Binding CurrentOrderItems.Count, Converter={StaticResource IntToBoolConverter}}"
                                VerticalOptions="Fill">
                            <StackLayout
                                Margin="0,4,0,4"
                                BindableLayout.ItemsSource="{Binding CurrentOrderItems}"
                                Spacing="12">
                                <BindableLayout.ItemTemplate>
                                    <DataTemplate x:DataType="Model:Product">
                                        <Border
                                            Padding="12"
                                            BackgroundColor="#F8F9FA"
                                            Stroke="#E9ECEF"
                                            StrokeShape="RoundRectangle 12"
                                            StrokeThickness="1">
                                            <Grid
                                                ColumnDefinitions="60,*,Auto"
                                                RowDefinitions="Auto"
                                                VerticalOptions="Fill">
                                                <!--  Product Image  -->
                                                <Border
                                                    Grid.Column="0"
                                                    BackgroundColor="White"
                                                    HeightRequest="60"
                                                    StrokeShape="RoundRectangle 8"
                                                    VerticalOptions="Start"
                                                    WidthRequest="60">
                                                    <Image
                                                        Margin="4"
                                                        Aspect="AspectFit"
                                                        Source="{Binding ImageUrl}"/>
                                                </Border>

                                                <!--  Product Info  -->
                                                <VerticalStackLayout
                                                    Grid.Column="1"
                                                    Margin="12,0,8,0"
                                                    Spacing="6"
                                                    VerticalOptions="Fill">
                                                    <Label
                                                        FontFamily="PoppinsBold"
                                                        FontSize="15"
                                                        LineBreakMode="TailTruncation"
                                                        Text="{Binding Name}"
                                                        TextColor="{StaticResource NPTextMain}"
                                                        VerticalOptions="Start"/>

                                                    <Label
                                                        FontFamily="PoppinsBold"
                                                        FontSize="14"
                                                        Text="{Binding Price, StringFormat='{0:C}'}"
                                                        TextColor="{StaticResource NPPrimaryBlue}"
                                                        VerticalOptions="Start"/>

                                                    <!--  Quantity Controls  -->
                                                    <HorizontalStackLayout
                                                        Margin="0,6,0,0"
                                                        Spacing="8"
                                                        VerticalOptions="End">
                                                        <!--  Decrease Quantity Button  -->
                                                        <Button
                                                            Padding="0"
                                                            BackgroundColor="{StaticResource NPTextSecondary}"
                                                            Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.DecrementQuantityCommand}"
                                                            CommandParameter="{Binding .}"
                                                            CornerRadius="12"
                                                            FontFamily="PoppinsBold"
                                                            FontSize="14"
                                                            HeightRequest="24"
                                                            Text="−"
                                                            TextColor="White"
                                                            WidthRequest="24"/>
                                                        <!--  Quantity Display  -->
                                                        <Border
                                                            Padding="8,4"
                                                            BackgroundColor="White"
                                                            MinimumWidthRequest="32"
                                                            Stroke="#E0E0E0"
                                                            StrokeShape="RoundRectangle 8"
                                                            StrokeThickness="1">
                                                            <Label
                                                                FontFamily="PoppinsBold"
                                                                FontSize="13"
                                                                HorizontalTextAlignment="Center"
                                                                Text="{Binding Stock}"
                                                                TextColor="{StaticResource NPTextMain}"
                                                                VerticalTextAlignment="Center"/>
                                                        </Border>
                                                        <!--  Increase Quantity Button  -->
                                                        <Button
                                                            Padding="0"
                                                            BackgroundColor="{StaticResource NPPrimaryBlue}"
                                                            Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.IncrementQuantityCommand}"
                                                            CommandParameter="{Binding .}"
                                                            CornerRadius="12"
                                                            FontFamily="PoppinsBold"
                                                            FontSize="14"
                                                            HeightRequest="24"
                                                            Text="+"
                                                            TextColor="White"
                                                            WidthRequest="24"/>
                                                    </HorizontalStackLayout>
                                                </VerticalStackLayout>

                                                <!--  Remove Button  -->
                                                <Button
                                                    Grid.Column="2"
                                                    Padding="0"
                                                    BackgroundColor="#FF6B6B"
                                                    Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.RemoveFromCartCommand}"
                                                    CommandParameter="{Binding .}"
                                                    CornerRadius="15"
                                                    FontFamily="PoppinsBold"
                                                    FontSize="18"
                                                    HeightRequest="30"
                                                    Text="×"
                                                    TextColor="White"
                                                    VerticalOptions="Start"
                                                    WidthRequest="30"/>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </BindableLayout.ItemTemplate>
                            </StackLayout>
                        </ScrollView>

                        <!--  Empty Cart State  -->
                        <VerticalStackLayout
                            Margin="24"
                            HorizontalOptions="Center"
                            IsVisible="{Binding CurrentOrderItems.Count, Converter={StaticResource IntToInverseBoolConverter}}"
                            Spacing="20"
                            VerticalOptions="Center">

                            <!--  Empty Cart Icon  -->
                            <Border
                                BackgroundColor="#F8F9FA"
                                HeightRequest="100"
                                HorizontalOptions="Center"
                                Stroke="#E9ECEF"
                                StrokeShape="Ellipse"
                                StrokeThickness="2"
                                WidthRequest="100">
                                <Label
                                    FontSize="42"
                                    HorizontalOptions="Center"
                                    Text="🛒"
                                    VerticalOptions="Center"/>
                            </Border>

                            <!--  Empty Message  -->
                            <VerticalStackLayout HorizontalOptions="Center"
                                    Spacing="12">
                                <Label
                                    FontFamily="PoppinsBold"
                                    FontSize="20"
                                    HorizontalTextAlignment="Center"
                                    Text="Your cart is empty"
                                    TextColor="{StaticResource NPTextMain}"/>
                                <Label
                                    Margin="20,0"
                                    FontSize="15"
                                    HorizontalTextAlignment="Center"
                                    LineBreakMode="WordWrap"
                                    Text="Select products from the left to add them to your order"
                                    TextColor="{StaticResource NPTextSecondary}"/>
                            </VerticalStackLayout>
                        </VerticalStackLayout>
                    </Grid>
                </Border>
                <!--  Summary and Action Buttons (panel background)  -->
                <StackLayout
                    Grid.Row="4"
                    Padding="24,16,24,16"
                    BackgroundColor="{StaticResource NPDivider}">
                    <Grid RowDefinitions="Auto,Auto,Auto,Auto">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Label
                            StyleClass="NormalText"
                            Text="Subtotal"
                            TextColor="{StaticResource NPTextSecondary}"/>
                        <Label
                            Grid.Column="1"
                            StyleClass="NormalText"
                            Text="{Binding Subtotal, StringFormat='${0:F2}'}"
                            TextColor="{StaticResource NPTextMain}"/>
                        <Label
                            Grid.Row="1"
                            StyleClass="NormalText"
                            Text="{Binding TaxRate, StringFormat='Tax ({0:F1}%)'}"
                            TextColor="{StaticResource NPTextSecondary}">
                            <Label.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding EditTaxCommand}"/>
                            </Label.GestureRecognizers>
                        </Label>
                        <Label
                            Grid.Row="1"
                            Grid.Column="1"
                            StyleClass="NormalText"
                            Text="{Binding Tax, StringFormat='${0:F2}'}"
                            TextColor="{StaticResource NPTextMain}"/>
                        <Label
                            Grid.Row="2"
                            StyleClass="NormalText"
                            Text="Discount"
                            TextColor="{StaticResource NPTextSecondary}"/>
                        <Border
                            Grid.Row="2"
                            Grid.Column="1"
                            BackgroundColor="White"
                            Stroke="#E0E0E0"
                            StrokeShape="RoundRectangle 5"
                            StrokeThickness="0.5">
                            <Entry
                                x:Name="DiscountEntry"
                                FontFamily="PoppinsBold"
                                FontSize="14"
                                HorizontalTextAlignment="Center"
                                Keyboard="Numeric"
                                Placeholder="$0.00"
                                Text="{Binding Discount, StringFormat='{0:F2}', Mode=TwoWay}"
                                TextColor="{StaticResource NPTextMain}"
                                WidthRequest="80"/>
                        </Border>
                        <Label
                            Grid.Row="3"
                            StyleClass="TitleText"
                            Text="Total"
                            TextColor="{StaticResource NPTextMain}"/>
                        <Label
                            Grid.Row="3"
                            Grid.Column="1"
                            StyleClass="TitleText"
                            Text="{Binding Total, StringFormat='${0:F2}'}"
                            TextColor="{StaticResource NPPrimaryBlue}"/>
                    </Grid>
                    <HorizontalStackLayout Margin="0,16,0,0"
                            Spacing="12">
                        <Button
                            BackgroundColor="{StaticResource NPTextMain}"
                            CornerRadius="8"
                            FontFamily="PoppinsBold"
                            HeightRequest="48"
                            Text="Cash"
                            TextColor="White"/>
                        <Button
                            BackgroundColor="{StaticResource NPAccentYellow}"
                            CornerRadius="8"
                            FontFamily="PoppinsBold"
                            HeightRequest="48"
                            Text="On Tab"
                            TextColor="White"/>
                    </HorizontalStackLayout>
                </StackLayout>
            </Grid>
        </Border>
    </Grid>
</ContentPage>