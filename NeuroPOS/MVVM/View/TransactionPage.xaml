<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="NeuroPOS.MVVM.View.TransactionPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:Converters="clr-namespace:NeuroPOS.Converters"
    xmlns:syncfusion="clr-namespace:Syncfusion.Maui.DataGrid;assembly=Syncfusion.Maui.DataGrid"
    BackgroundColor="{StaticResource NPLightBg}">
    <ContentPage.Resources>
        <Converters:TransactionTypeToColorConverter x:Key="TransactionTypeToColorConverter" />

    </ContentPage.Resources>

    <!--  Main background  -->


    <VerticalStackLayout Padding="32,32,32,24" Spacing="24">
        <!--  Title Section  -->
        <Label
            Margin="0,0,0,2"
            FontSize="28"
            StyleClass="TitleText"
            Text="Transactions" />
        <Label
            Margin="0,0,0,18"
            FontSize="16"
            StyleClass="SubtitleText"
            Text="View and manage all transactions" />

        <!--  Floating Filter Bar  -->
        <Border
            Margin="0,0,0,10"
            Padding="18,10"
            BackgroundColor="White"
            StrokeShape="RoundRectangle 16">
            <Border.Shadow>
                <Shadow
                    Brush="Black"
                    Opacity="0.10"
                    Radius="10"
                    Offset="0,2" />
            </Border.Shadow>
            <HorizontalStackLayout Spacing="12">
                <Entry
                    BackgroundColor="{StaticResource NPLightBg}"
                    HeightRequest="36"
                    HorizontalOptions="Fill"
                    Placeholder="Search transactions..." />
                <Button
                    Padding="16,0"
                    BackgroundColor="{StaticResource NPPrimaryBlue}"
                    CornerRadius="8"
                    FontAttributes="Bold"
                    HeightRequest="36"
                    Text="Date Range"
                    TextColor="White" />
                <Button
                    Padding="16,0"
                    BackgroundColor="{StaticResource NPPrimaryBlue}"
                    CornerRadius="8"
                    FontAttributes="Bold"
                    HeightRequest="36"
                    Text="Status"
                    TextColor="White" />
            </HorizontalStackLayout>
        </Border>

        <!--  Card with shadow for DataGrid  -->
        <Border
            Padding="0,0,0,10"
            BackgroundColor="{StaticResource NPCardBg}"
            HeightRequest="500"
            StrokeThickness="1"
            StyleClass="CardStyle">
            <Border.Shadow>
                <Shadow
                    Brush="Black"
                    Opacity="0.15"
                    Radius="16"
                    Offset="0,4" />
            </Border.Shadow>


        </Border>
    </VerticalStackLayout>
</ContentPage>